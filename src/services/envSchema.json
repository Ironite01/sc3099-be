{
    "type": "object",
    "required": [
        "PORT",
        "FRONTEND_URL",
        "ML_URL",
        "DASHBOARD_URL",
        "DATABASE_URL",
        "SECRET_KEY",
        "REDIS_URL"
    ],
    "properties": {
        "REDIS_LIMIT_HIGH": {
            "type": "string",
            "default": "true"
        },
        "PORT": {
            "type": "string",
            "default": 8000
        },
        "FRONTEND_URL": {
            "type": "string",
            "default": "http://localhost:3000"
        },
        "ML_URL": {
            "type": "string",
            "default": "http://localhost:8001"
        },
        "DASHBOARD_URL": {
            "type": "string",
            "default": "http://localhost:8501"
        },
        "DATABASE_URL": {
            "type": "string",
            "default": "postgres://postgres:password@127.0.0.1/capstone"
        },
        "SECRET_KEY": {
            "type": "string",
            "default": "your-secret-key-change-this-in-production"
        },
        "REDIS_URL": {
            "type": "string",
            "default": "redis://localhost:6379"
        },
        "ACCESS_TOKEN_EXPIRE_MINUTES": {
            "type": "string",
            "default": 60
        },
        "REFRESH_TOKEN_EXPIRE_DAYS": {
            "type": "string",
            "default": 7
        },
        "BCRYPT_ROUNDS": {
            "type": "string",
            "default": 10
        },
        "RISK_SCORE_THRESHOLD": {
            "type": "string",
            "default": 0.5
        }
    }
}